---
import type { Lang } from "~/i18n";
import { t, pathFor, otherLang } from "~/i18n";

interface Props {
  lang: Lang;
  page: "home" | "contact";
}

const { lang, page } = Astro.props;
const d = t(lang);

const homeHref = pathFor(lang, "home");
const contactHref = pathFor(lang, "contact");

const links = [
  { href: `${homeHref === "/" ? "" : homeHref}#work`, label: d.nav.work },
  { href: `${homeHref === "/" ? "" : homeHref}#stack`, label: d.nav.stack },
  { href: contactHref, label: d.nav.contact },
];

const altLang = otherLang(lang);
const altHref = pathFor(altLang, page);
---

<header
  class="sticky top-0 z-50 backdrop-blur-xl border-b border-[color:var(--color-border)]/70"
  style="background-color: color-mix(in oklab, var(--color-bg) 78%, transparent);"
>
  <nav class="container-x flex items-center justify-between h-16 gap-4">
    <!-- Logo -->
    <a href={homeHref} class="flex items-center gap-2.5 font-bold tracking-tight text-[15px] sm:text-base whitespace-nowrap">
      <span
        class="inline-block size-2 rounded-[2px] bg-[color:var(--color-pink)] shadow-[0_0_14px_var(--color-pink)]"
        aria-hidden="true"
      ></span>
      <span class="text-[color:var(--color-text)]">Carlo Maria Cardi</span>
    </a>

    <!-- Section links -->
    <ul class="hidden md:flex items-center gap-7 text-sm text-[color:var(--color-text-dim)]">
      {links.map((l) => (
        <li>
          <a href={l.href} class="font-medium hover:text-[color:var(--color-text)] transition-colors">
            {l.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-1.5">
      <!-- Lang switch -->
      <a
        href={altHref}
        aria-label={altLang === "en" ? "Switch to English" : "Passa all'italiano"}
        class="font-mono text-[11px] uppercase tracking-widest px-2.5 py-1.5 rounded-[6px] border border-[color:var(--color-border)] text-[color:var(--color-text-dim)] hover:text-[color:var(--color-text)] hover:border-[color:var(--color-border-hover)] transition-colors"
      >
        {altLang}
      </a>

      <!-- Theme toggle -->
      <button
        type="button"
        data-theme-toggle
        aria-label="Toggle theme"
        class="inline-flex items-center justify-center size-[34px] rounded-[6px] border border-[color:var(--color-border)] text-[color:var(--color-text-dim)] hover:text-[color:var(--color-text)] hover:border-[color:var(--color-border-hover)] transition-colors"
      >
        <svg class="size-4 hidden dark-only" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
        </svg>
        <svg class="size-4 hidden light-only" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- GitHub CTA -->
      <a
        href="https://github.com/MathsAnalysis"
        target="_blank"
        rel="noopener"
        class="hidden sm:inline-flex font-mono text-[11px] uppercase tracking-widest px-3 py-1.5 rounded-[6px] border border-[color:var(--color-border)] text-[color:var(--color-text-dim)] hover:text-[color:var(--color-text)] hover:border-[color:var(--color-border-hover)] transition-colors"
      >
        {d.nav.github}
      </a>
    </div>
  </nav>
</header>

<style is:global>
  html[data-theme="dark"] .dark-only { display: inline-block; }
  html[data-theme="light"] .light-only { display: inline-block; }
</style>
