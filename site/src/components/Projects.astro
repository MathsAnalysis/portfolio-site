---
import { t, type Lang } from "~/i18n";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const d = t(lang);

interface Project {
  key: string;
  name: string;
  tagline: string;
  description: string;
  stack: string[];
  repo: string;
  live?: string;
  role: string;
  accent: "cyan" | "accent" | "amber";
}

const projects: Project[] = [
  {
    key: "axiom",
    name: "Axiom AntiVPN",
    role: d.projects.roleCreator,
    tagline: d.projects.cards.axiom.tagline,
    description: d.projects.cards.axiom.description,
    stack: ["Python", "TypeScript", "ML models", "Cloudflare"],
    repo: "https://github.com/Axiom-Enterprise/antipvn-checker",
    live: "https://antivpn.mathsanalysis.com",
    accent: "cyan" as const,
  },
  {
    key: "shardify",
    name: "Shardify",
    role: d.projects.roleAuthor,
    tagline: d.projects.cards.shardify.tagline,
    description: d.projects.cards.shardify.description,
    stack: ["Java", "Redis", "PostgreSQL", "MongoDB"],
    repo: "https://github.com/MathsAnalysis/Shardify",
    accent: "accent" as const,
  },
  {
    key: "brain4j",
    name: "Brain4J",
    role: d.projects.roleContributor,
    tagline: d.projects.cards.brain4j.tagline,
    description: d.projects.cards.brain4j.description,
    stack: ["Java", "JVM perf", "API design"],
    repo: "https://github.com/brain4j-org/brain4j",
    accent: "amber" as const,
  },
];

const accentClass: Record<Project["accent"], string> = {
  cyan: "text-[color:var(--color-cyan)]",
  accent: "text-[color:var(--color-accent)]",
  amber: "text-[color:var(--color-amber)]",
};
---

<section id="work" class="relative py-24 sm:py-32 border-t border-[color:var(--color-border)]/60">
  <div class="container-x">
    <div class="mb-14 flex items-end justify-between gap-8 flex-wrap">
      <div>
        <p class="reveal font-mono text-xs uppercase tracking-[0.2em] text-[color:var(--color-text-muted)] mb-3">
          {d.projects.sectionLabel}
        </p>
        <h2 class="reveal text-3xl sm:text-4xl font-semibold tracking-tight">
          {d.projects.title}
        </h2>
      </div>
      <p class="reveal max-w-md text-sm text-[color:var(--color-text-dim)]">
        {d.projects.intro}
      </p>
    </div>

    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {projects.map((p, i) => (
        <article
          class="reveal glow-border group relative flex flex-col rounded-[14px] border border-[color:var(--color-border)] bg-[color:var(--color-bg-card)] p-6 sm:p-7 transition-colors hover:border-[color:var(--color-border-hover)]"
          style={`transition-delay: ${i * 60}ms`}
        >
          <div class="flex items-start justify-between gap-3 mb-4">
            <span class={`font-mono text-[11px] uppercase tracking-[0.14em] ${accentClass[p.accent]}`}>
              {p.role}
            </span>
            {p.live && (
              <span class="inline-flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-wider text-[color:var(--color-accent)]">
                <span class="size-1.5 rounded-full bg-[color:var(--color-accent)] animate-pulse"></span>
                {d.projects.liveBadge}
              </span>
            )}
          </div>

          <h3 class="text-2xl font-semibold tracking-tight mb-2">{p.name}</h3>
          <p class="text-sm text-[color:var(--color-text-dim)] mb-4">{p.tagline}</p>
          <p class="text-sm text-[color:var(--color-text-dim)] leading-relaxed mb-6 flex-1">
            {p.description}
          </p>

          <ul class="flex flex-wrap gap-1.5 mb-6">
            {p.stack.map((s) => (
              <li class="font-mono text-[11px] px-2 py-0.5 rounded-md border border-[color:var(--color-border)] text-[color:var(--color-text-dim)]">
                {s}
              </li>
            ))}
          </ul>

          <div class="flex items-center gap-4 text-sm">
            <a
              href={p.repo}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1.5 text-[color:var(--color-text)] hover:text-[color:var(--color-accent)] transition-colors"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" class="size-4" aria-hidden="true">
                <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.92.58.11.79-.25.79-.56v-2c-3.2.7-3.88-1.36-3.88-1.36-.52-1.32-1.28-1.67-1.28-1.67-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.72-1.54-2.56-.29-5.26-1.28-5.26-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 2.9-.39c.98 0 1.97.13 2.9.39 2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.4-5.27 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56C20.22 21.38 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5Z"/>
              </svg>
              {d.projects.repoLabel}
            </a>
            {p.live && (
              <a
                href={p.live}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-1.5 text-[color:var(--color-cyan)] hover:underline"
              >
                {d.projects.liveLabel}
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
