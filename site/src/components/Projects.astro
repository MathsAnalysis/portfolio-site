---
import { t, type Lang } from "~/i18n";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const d = t(lang);

interface Project {
  key: string;
  name: string;
  tagline: string;
  description: string;
  stack: string[];
  repo: string;
  live?: string;
  role: string;
  accent: "cyan" | "accent" | "amber";
}

const projects: Project[] = [
  {
    key: "axiom",
    name: "Axiom AntiVPN",
    role: d.projects.roleCreator,
    tagline: d.projects.cards.axiom.tagline,
    description: d.projects.cards.axiom.description,
    stack: ["Python", "TypeScript", "ML models", "Cloudflare"],
    repo: "https://github.com/Axiom-Enterprise/antipvn-checker",
    live: "https://antivpn.mathsanalysis.com",
    accent: "cyan" as const,
  },
  {
    key: "shardify",
    name: "Shardify",
    role: d.projects.roleAuthor,
    tagline: d.projects.cards.shardify.tagline,
    description: d.projects.cards.shardify.description,
    stack: ["Java", "Redis", "PostgreSQL", "MongoDB"],
    repo: "https://github.com/MathsAnalysis/Shardify",
    accent: "accent" as const,
  },
  {
    key: "brain4j",
    name: "Brain4J",
    role: d.projects.roleContributor,
    tagline: d.projects.cards.brain4j.tagline,
    description: d.projects.cards.brain4j.description,
    stack: ["Java", "JVM perf", "API design"],
    repo: "https://github.com/brain4j-org/brain4j",
    accent: "amber" as const,
  },
];

const gradientVar: Record<string, string> = {
  axiom:    "var(--grad-axiom)",
  shardify: "var(--grad-shardify)",
  brain4j:  "var(--grad-brain4j)",
};

const abbrev: Record<string, string> = {
  axiom:    "AXIOM",
  shardify: "SHARD",
  brain4j:  "BRAIN4J",
};

function rowNum(i: number): string {
  return String(i + 1).padStart(2, "0");
}
---

<section id="work" class="relative py-24 sm:py-32 border-t border-[color:var(--color-border)]">
  <div class="container-x">

    <!-- Section header -->
    <div class="mb-14 flex items-start justify-between gap-10 flex-wrap">
      <div>
        <p class="reveal font-mono text-xs uppercase tracking-[0.2em] text-[color:var(--color-text-muted)] mb-4">
          {d.projects.sectionLabel}
        </p>
        <h2 class="reveal text-5xl sm:text-7xl font-black tracking-[-0.03em]">
          {d.projects.title}
        </h2>
      </div>
      <p class="reveal max-w-sm text-sm text-[color:var(--color-text-dim)] mt-8 sm:mt-14">
        {d.projects.intro}
      </p>
    </div>

    <!-- Project rows -->
    <div class="space-y-6">
      {projects.map((p, i) => {
        const isEven = i % 2 === 0;
        return (
          <article
            class="reveal tile rounded-[16px] overflow-hidden border border-[color:var(--color-border)] grid grid-cols-1 md:grid-cols-12"
            style={`transition-delay: ${i * 60}ms`}
          >
            <!-- Text panel -->
            <div
              class={[
                "md:col-span-7 bg-[color:var(--color-bg-card)] p-8 sm:p-12 flex flex-col justify-between gap-10",
                !isEven ? "md:order-2" : "",
              ].join(" ")}
            >
              <!-- Top meta row: role label + row number -->
              <div class="flex items-center justify-between gap-4">
                <span class="font-mono text-[11px] uppercase tracking-widest text-[color:var(--color-text-muted)]">
                  {p.role}
                </span>
                <span class="font-mono text-2xl font-bold text-[color:var(--color-text-muted)]">
                  {rowNum(i)}
                </span>
              </div>

              <!-- Project name -->
              <div>
                <h3 class="text-4xl sm:text-6xl font-black tracking-[-0.03em] leading-none mt-8">
                  {p.name}
                </h3>
                <p class="text-lg text-[color:var(--color-text-dim)] mt-4 max-w-md">
                  {p.tagline}
                </p>
              </div>

              <!-- Stack pills -->
              <ul class="flex flex-wrap gap-2">
                {p.stack.map((s) => (
                  <li class="font-mono text-xs px-2 py-1 rounded-sm border border-[color:var(--color-border)] text-[color:var(--color-text-dim)]">
                    {s}
                  </li>
                ))}
              </ul>

              <!-- Links -->
              <div class="flex flex-wrap items-center gap-6 mt-auto">
                <a
                  href={p.repo}
                  target="_blank"
                  rel="noopener"
                  class="font-mono text-sm text-[color:var(--color-text-dim)] underline-offset-4 hover:underline hover:text-[color:var(--color-text)] transition-colors"
                >
                  {d.projects.repoLabel} &uarr;&nearr;
                </a>
                {p.live && (
                  <a
                    href={p.live}
                    target="_blank"
                    rel="noopener"
                    class="font-mono text-sm text-[color:var(--color-cyan)] underline-offset-4 hover:underline transition-colors"
                  >
                    {d.projects.liveLabel}
                  </a>
                )}
              </div>
            </div>

            <!-- Graphic panel -->
            <div
              class={[
                "md:col-span-5 relative overflow-hidden min-h-[260px] md:min-h-0",
                !isEven ? "md:order-1" : "",
              ].join(" ")}
              style={`background: ${gradientVar[p.key]}`}
            >
              {/* LIVE badge */}
              {p.live && (
                <span class="-rotate-2 absolute top-6 left-6 inline-flex items-center px-3 py-1 rounded-full bg-white text-black font-mono text-[10px] uppercase tracking-widest shadow-md select-none z-10">
                  {d.projects.liveBadge}
                </span>
              )}

              {/* Giant abbreviation — editorial bleed */}
              <span
                class="tile-mega font-black text-black uppercase absolute bottom-6 right-6 text-right leading-none select-none opacity-90"
                aria-hidden="true"
              >
                {abbrev[p.key]}
              </span>
            </div>
          </article>
        );
      })}
    </div>

  </div>
</section>
