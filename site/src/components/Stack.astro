---
import { t, type Lang } from "~/i18n";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const d = t(lang);
---

<section id="stack" class="relative py-24 sm:py-32 border-t border-[color:var(--color-border)]/60">
  <div class="container-x">
    <div class="mb-14 max-w-2xl">
      <p class="reveal font-mono text-xs uppercase tracking-[0.2em] text-[color:var(--color-text-muted)] mb-3">
        {d.stack.sectionLabel}
      </p>
      <h2 class="reveal text-3xl sm:text-4xl font-semibold tracking-tight">
        {d.stack.title1}<br />{d.stack.title2} <em class="not-italic text-[color:var(--color-cyan)]">{d.stack.titleEm}</em>.
      </h2>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {d.stack.groups.map((g) => (
        <div class="reveal rounded-[14px] border border-[color:var(--color-border)] bg-[color:var(--color-bg-elev)] p-6">
          <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-[color:var(--color-text-muted)] mb-4">
            {g.label}
          </p>
          <ul class="flex flex-wrap gap-1.5">
            {g.items.map((it) => (
              <li class="font-mono text-xs px-2.5 py-1 rounded-md border border-[color:var(--color-border)] text-[color:var(--color-text-dim)] hover:text-[color:var(--color-text)] hover:border-[color:var(--color-border-hover)] transition-colors">
                {it}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
