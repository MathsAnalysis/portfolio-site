# ─────────────────────────────────────────────────────────
# Portfolio stack — environment reference
#
# Copy this file to .env and fill in values for the features you want.
# Empty values disable the corresponding subsystem; the app will still run
# (it just logs "disabled" and skips email/auth/etc).
# ─────────────────────────────────────────────────────────

# ─── Postgres (required) ───
POSTGRES_PASSWORD=change_me_in_production

# ─── Phase 1 dev bypass ───
# When set, every /admin request is authenticated as this user. Keep empty
# in production once CF Access is wired up.
ADMIN_MOCK_EMAIL=

# ─── Phase 3: Cloudflare Access ───
# Team domain shown in Cloudflare Zero Trust → Settings → Custom Pages →
# Your team domain. Do NOT include "https://".
CF_ACCESS_TEAM_DOMAIN=
# The "AUD" tag shown in your Access application settings.
CF_ACCESS_AUDIENCE=

# ─── Turnstile (Cloudflare challenge) ───
# Secret key from dashboard → Turnstile → your site.
TURNSTILE_SECRET=

# ─── Internal SMTP (for notifications TO Carlo) ───
# Pointed at the axiom-mailserver container on the shared docker network.
SMTP_HOST=axiom-mailserver
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Portfolio <noreply@mathsanalysis.com>
SMTP_TO=carlo4340@outlook.it
SMTP_USE_TLS=false
SMTP_SKIP_VERIFY=true

# ─── Resend (outbound visitor replies) ───
# Sign up at resend.com, verify mathsanalysis.com with DKIM/SPF.
RESEND_API_KEY=
RESEND_FROM=Carlo Maria Cardi <replies@mathsanalysis.com>
RESEND_DOMAIN=mathsanalysis.com

# ─── Inbound email webhook (shared HMAC secret) ───
# Generate with: openssl rand -hex 32
# Must match wrangler secret INBOUND_WEBHOOK_SECRET in cf-worker/.
INBOUND_WEBHOOK_SECRET=
